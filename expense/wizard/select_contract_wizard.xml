<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_select_contract_wizard_form" model="ir.ui.view">
            <field name="name">select.contract.wizard</field>
            <field name="model">select.contract.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Daily Report">
                    <group>
                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="expense_type"/>
                        </group>
                        <group>
                            <field name="contract_id" domain="[('employee_id', '=', employee_id), ('state', '=', 'run'), ('advance_subtract', '=', False), ('loan_subtract', '=', False)]" options="{'no_quick_create': True, 'no_create_edit' : True}" required="1"/>
                            <field name="contract_type" readonly="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_validate" string="Validate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_select_contract_wizard_action" model="ir.actions.act_window">
            <field name="name">Daily Report</field>
            <field name="res_model">select.contract.wizard</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>

        </record>

    </data>
</odoo>