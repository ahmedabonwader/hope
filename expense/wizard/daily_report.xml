<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_daily_report_form" model="ir.ui.view">
            <field name="name">Daily Report</field>
            <field name="model">daily.expense.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Daily Report">
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="allowed_user_ids" widget="many2many_tags" invisible="1"/>
                            <field name="user_id" invisible="report_type == 'loan'" domain="[('id', 'in', allowed_user_ids)]" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                            <field name="employee_ids" widget="many2many_tags" options="{'no_quick_create': True, 'no_create_edit' : True}"
                                   invisible="report_type == 'expense'"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_report" string="Print" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_daily_report_action" model="ir.actions.act_window">
            <field name="name">Daily Report</field>
            <field name="res_model">daily.expense.report</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>

        </record>

    </data>
</odoo>