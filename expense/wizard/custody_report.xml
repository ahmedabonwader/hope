<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_expense_custody_report_form" model="ir.ui.view">
            <field name="name">expense.custody.report</field>
            <field name="model">expense.custody.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Daily Report">
                    <group>
                        <group>
                            <field name="account_id"/>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="journal_ids" widget="many2many_tags" domain="[('default_account_id', '=', account_id)]" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                            <field name="date_to"></field>
                        </group>
                    </group>
                    <notebook>
                        <page name="name" string="Authorized">
                            <group>
                                <group>
                                    <field name="signature_prepared"/>
                                    <field name="signature_reviewed"/>
                                </group>
                                <group>
                                    <field name="signature_approved"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_print_report" string="Print" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_expense_custody_report_action" model="ir.actions.act_window">
            <field name="name">Custody Report</field>
            <field name="res_model">expense.custody.report</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>