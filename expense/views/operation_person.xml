<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_oms_operation_person_list" model="ir.ui.view">
        <field name="name">oms.operation.person.list</field>
        <field name="model">oms.operation.person</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="expense_department"/>
            </list>
        </field>
    </record>

    <record id="view_oms_operation_person_form" model="ir.ui.view">
        <field name="name">oms.operation.person.form</field>
        <field name="model">oms.operation.person</field>
        <field name="arch" type="xml">
            <form>
                
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="expense_department"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter -->
                <chatter reload_on_attachment="True"/>
            </form>
        </field>
    </record>

    <record id="view_oms_operation_person_search" model="ir.ui.view">
        <field name="name">oms.operation.person.search</field>
        <field name="model">oms.operation.person</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
            </search>
        </field>
    </record>

    <record id="action_oms_operation_person" model="ir.actions.act_window">
        <field name="name">Operation Person</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">oms.operation.person</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Your First Operation Person
            </p>
        </field>
    </record>

    

</odoo>
