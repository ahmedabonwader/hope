<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_oms_advance_loan_conf_list" model="ir.ui.view">
        <field name="name">oms.advance.loan.conf.list</field>
        <field name="model">oms.advance.loan.conf</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="operation_type"/>
                <field name="maximum_percentage"/>
            </list>
        </field>
    </record>

    <record id="view_oms_advance_loan_conf_form" model="ir.ui.view">
        <field name="name">oms.advance.loan.conf.form</field>
        <field name="model">oms.advance.loan.conf</field>
        <field name="arch" type="xml">
            <form>
                <header>
                   
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="operation_type" widget="radio" options="{'horizontal':true}"/>
                        </group>
                        <group>
                            
                            <field name="maximum_percentage"/>
                        
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_oms_advance_loan_conf_search" model="ir.ui.view">
        <field name="name">oms.advance.loan.conf.search</field>
        <field name="model">oms.advance.loan.conf</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_oms_advance_loan_conf" model="ir.actions.act_window">
        <field name="name">Loan / Advance</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">oms.advance.loan.conf</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Your First Record
            </p>
        </field>
    </record>

    
</odoo>
