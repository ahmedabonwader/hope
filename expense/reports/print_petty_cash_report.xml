<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="action_report_petty_cash_payment_info">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="doc">
                    <div style="text-align: center; font-family: KacstOne; color: #003366;">
                        <h3 style="text-decoration: underline;">
                            <span t-field="doc.company_id.name"/>
                        </h3>
                        <h3 style="text-decoration: underline;">Finance Management</h3>
                        <h3 style="text-decoration: underline;">Annex 8: Petty Cash Payment And Receipt Voucher</h3>
                    </div>
                    <br/>
                    <br/>
                    <br/>
                    <div class="row my-1"
                        style="font-size:13px; width:100%; text-align:center; margin-bottom:10px; margin-top:10px;">
                        <div class="col-4">
                            <h6 class="text-center" style="color: #FFBF00;">
                                <strong>Date</strong>
                            </h6>
                            <div class="row">
                                <div class="col-12 text-center">
                                    <span t-field="doc.time" style="font-size: 16px; color: #003366;"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <h6 class="text-center" style="color: #FFBF00;">
                                <strong>Payee Name</strong>
                            </h6>
                            <div class="row">
                                <div class="col-12 text-center">
                                    <span t-field="doc.partner_id.name" style="font-size: 16px; color: #003366;"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-4">
                            <h6 class="text-center" style="color: #FFBF00;">
                                <strong>Requester By</strong>
                            </h6>
                            <div class="row">
                                <div class="col-12 text-center">
                                    <span t-field="doc.user_id.name" style="font-size: 16px; color: #003366;"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <br/>
                    <br/>
                    <br/>
                    <div style="margin-top: 5px;">
                        <table class="table table-sm" dir="rtl" style="width: 100%; table-layout: fixed;">
                            <thead>
                                <tr>
                                    <th>Total Amount</th>
                                    <th>Unit Price</th>
                                    <th>QTY</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.expense_line_ids" t-as="line">
                                    <tr>
                                        <td style="text-align:left;">
                                            <span t-field="line.total_amount"/>
                                        </td>
                                        <td style="text-align:left;">
                                            <span t-field="line.unit_price"/>
                                        </td>
                                        <td style="text-align:left;">
                                            <span t-field="line.qty"/>
                                        </td>
                                        <td style="text-align:left;">
                                            <span t-field="line.pro_id.name"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <br/>
                        <br/>
                        <br/>
                        <table class="o_has_total_table table o_main_table table-borderless mt-4">
                            <thead>
                                <tr>
                                    <th class="text-start">
                                        <strong>Position</strong>
                                    </th>
                                    <th class="text-start">
                                        <strong>Name</strong>
                                    </th>
                                    <th class="text-start">
                                        <strong>Signature</strong>
                                    </th>
                                    <th class="text-start">
                                        <strong>Date</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Prepared by</td>
                                    <td>
                                        <span t-field="doc.user_id.name"/>
                                    </td>
                                    <td><img t-if="doc.user_id.digital_signature" t-att-src="image_data_uri(doc.user_id.digital_signature)" style="max-height: 50px;" alt="signature"/></td>
                                    <td>
                                        <span t-field="doc.time"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Reviewed by</td>
                                    <td>
                             
                                        <span t-if="doc.operation_department == 'hr_expense'" t-field="doc.sign_hr_reviewed"/>

                                    
                                        <span t-if="doc.operation_department == 'finance_expense' or doc.operation_department == 'hybird'" t-field="doc.sign_reviewed"/>
                                    </td>
                                    <td>
                                        
                                        <img t-if="doc.operation_department == 'hr_expense' and doc.signature_hr_approved.digital_signature"
                                            t-att-src="image_data_uri(doc.signature_hr_approved.digital_signature)"
                                            style="max-height: 50px;"
                                            alt="signature"/>

                                        <img t-if="(doc.operation_department == 'finance_expense' or doc.operation_department == 'hybird') and doc.signature_reviewed.digital_signature"
                                            t-att-src="image_data_uri(doc.signature_reviewed.digital_signature)"
                                            style="max-height: 50px;"
                                            alt="signature"/>
                                    </td>

                                    <td>
                                        <span t-field="doc.date_review"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Approved by</td>
                                    <td>
                                        <span t-field="doc.sign_approved"/>
                                    </td>
                                    <td>
                                        <img t-if="doc.signature_approved.digital_signature"
                                            t-att-src="image_data_uri(doc.signature_approved.digital_signature)"
                                            style="max-height: 50px;"
                                            alt="signature"/>
                                    </td>
                                    <td>
                                        <span t-field="doc.date_approve"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Paid by</td>
                                    <td>
                                        <span t-field="doc.payment_method.name"/>
                                    </td>
                                    <td>
                                        <img t-if="doc.payment_method.user_id.digital_signature"
                                            t-att-src="image_data_uri(doc.payment_method.user_id.digital_signature)"
                                            style="max-height: 50px;"
                                            alt="signature"/>
                                    </td>
                                    <td>
                                        <span t-field="doc.move_id.invoice_date"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_petty_cash_payment" model="ir.actions.report">
        <field name="name">Petty Cash Payment Report</field>
        <field name="model">hms.expense.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">expense.action_report_petty_cash_payment_info</field>
        <field name="report_file">expense.action_report_petty_cash_payment_info</field>
    </record>
</odoo>