<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_salary_payment_sheet_report_form" model="ir.ui.view">
            <field name="name">salary.payment.sheet.report</field>
            <field name="model">salary.payment.sheet.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Daily Report">
                    <group>
                        <group>
                            <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit' : True}"
                                   domain="[('project_id', '=', project_id), ('state', '=', 'run'), ('batches_id', '=', batches_id)]" invisible="salary_type != 'by_project'"
                                   required="salary_type == 'by_project'"/>
                            <field name="employee_id_contract" options="{'no_quick_create': True, 'no_create_edit' : True}"
                                   domain="[('batches_id', '=', batches_id)]" invisible="salary_type == 'by_project'"
                                   required="salary_type != 'by_project'"/>
                            <field name="batches_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="project_id" readonly="1" invisible="salary_type == 'by_contract'"/>
                            <field name="salary_type" readonly="1"/>
                            <field name="company_id" readonly="1" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="name" string="Paid By" invisible="1">
                            <group>
                                <group>
                                    <field name="user_id"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_print_report" string="Print" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_salary_payment_sheet_report_action" model="ir.actions.act_window">
            <field name="name">Salary Payment Sheet Report</field>
            <field name="res_model">salary.payment.sheet.report</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>