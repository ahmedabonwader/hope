<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_create_bank_letters_wizard_form" model="ir.ui.view">
            <field name="name">create.bank.letters.wizard</field>
            <field name="model">create.bank.letters.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Daily Report">
                    <group>
                        <group>
                            <field name="batches_id" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="date"/>
                        </group>
                        
                    </group>
                    <notebook>
                        <page name="name" string="Bank Details">
                            <group>
                                <group>
                                    <field name="bank_name_letter" placeholder="Enter The Bank Name You want to Addressed to" required="1"/>
                                    <field name="budget_code" required="1"/>
                                </group>
                                <group>
                                    <field name="bank" widget="radio" options="{'horizontal':true}" required="1"/>
                                    <field name="bank_branch" placeholder="Enter Branch Name" required="1"/>
                                    <field name="payment_number" placeholder="Enter Payment Number"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    
                    <footer>
                        <button name="action_validate" string="Validate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_create_bank_letters_wizard_action" model="ir.actions.act_window">
            <field name="name">Create Bank Letters Wizard</field>
            <field name="res_model">create.bank.letters.wizard</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>