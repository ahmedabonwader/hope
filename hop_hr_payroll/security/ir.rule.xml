<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> 
        <record id="payroll_project_administrator_rule" model="ir.rule">
            <field name="name">Payroll Admins - See All Project</field>
            <field name="model_id" ref="hop_hr_payroll.model_payslips_batches"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hop_hr_payroll.group_hr_payroll_admin'))]"/>
        </record>

        <record id="payroll_doner_project_rule" model="ir.rule">
            <field name="name">Payroll Donor - See Only Their Projects</field>
            <field name="model_id" ref="hop_hr_payroll.model_payslips_batches"/> 
            <field name="domain_force">[('project_id', 'in', user.project_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hop_hr_payroll.group_hr_payroll_donor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>