<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contract_template_reports_info">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" style="font-family: 'Times New Roman', serif; font-size: 16px; color: #000; line-height: 1.5;">
                    
                    <div class="header_section" style="border-bottom: 2px solid #333; padding-bottom: 15px;">
                        <div class="row" style="margin-bottom: 10px; align-items: center; display: flex;">
                            <div style="width: 20%; text-align: left;">
                                <t t-if="data[0].get('report_logo')">
                                    <img t-att-src="'data:image/png;base64,%s' % data[0]['report_logo']"
                                        style="max-height: 100px; max-width: 160px;"/>
                                </t>
                            </div>
                            <div style="width: 60%; text-align: center;">
                                <h2 style="text-decoration: underline; font-weight: bold; margin: 0; font-size: 26px;">EMPLOYMENT CONTRACT</h2>
                            </div>
                            <div style="width: 20%; text-align: right;">
                                <t t-if="data[0].get('report_logo')">
                                    <img t-att-src="'data:image/png;base64,%s' % data[0]['report_logo']"
                                        style="max-height: 100px; max-width: 160px;"/>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="body_section" style="margin-top: 35px;">
                        <div style="text-align: left; margin-bottom: 25px;">
                            <span style="font-weight: bold; font-size: 22px;">This contract is made between:</span>
                        </div>

                        <t t-foreach="data" t-as="line">
                            <p style="text-align: justify; line-height: 1.8; margin-bottom: 15px;">
                                <t t-if="line.get('has_offices')">
                                    <strong>HOPE</strong>, HQ office address at <t t-esc="line['hq_address']"/>, 
                                    Mobile: <t t-esc="line['hq_mobile']"/>, E-mail: <t t-esc="line['hq_email']"/>, 
                                    and State Office: <t t-esc="line['state_address']"/> 
                                    represented by the Country Director, <strong><t t-esc="line['hq_director']"/></strong> 
                                    (hereinafter referred to as <strong>HOPE</strong>),
                                </t>
                                <t t-else="">
                                    <strong>HOPE</strong>, represented by the Country Director (hereinafter referred to as <strong>HOPE</strong>),
                                </t>
                            </p>

                            <div style="text-align: center; font-weight: bold; margin: 15px 0; font-size: 20px;">&amp;</div>
 
                            <p style="text-align: justify; line-height: 1.8; margin-bottom: 20px;">
                                <strong t-if="line['gender'] == 'male'">Mr. </strong>
                                <strong t-elif="line['gender'] == 'female'">Ms. </strong>
                                <strong t-else="">Mr/Ms. </strong>
                                
                                <strong><t t-esc="line['employee']"/></strong> with the principal address: 
                                <t t-esc="line['employee_address']"/>, Mobile: <t t-esc="line['employee_mobile']"/>, 
                                Email: <t t-esc="line['employee_email']"/>, (hereinafter referred to as <strong>Employee</strong>),
                            </p>

                            <p style="font-weight: bold; margin-top: 30px; text-decoration: underline; font-size: 18px;">
                                The two parties agreed on the following:
                            </p>
                        </t>
                    </div>

                    <div class="body_section" style="margin-top: 20px;">
                        <t t-foreach="data" t-as="line">
                            <table class="table table-bordered" style="width: 100%; border: 1px solid #000; border-collapse: collapse; font-size: 16px;">
                                <tr style="border: 1px solid #000;">
                                    <td style="width: 5%; text-align: center; padding: 8px; border: 1px solid #000;">1.</td>
                                    <td style="width: 25%; font-weight: bold; padding: 8px; border: 1px solid #000;">Position</td>
                                    <td style="padding: 8px; border: 1px solid #000;">
                                        <strong t-esc="line['job_title']"/>
                                        <span t-esc="line['project_suffix']"/>
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">2.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Duration of Contract</td>
                                    <td style="padding: 8px; border: 1px solid #000;"><t t-esc="line['duration_val']"/></td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">3.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Location</td>
                                    <td style="padding: 8px; border: 1px solid #000;">
                                        <strong t-esc="line['main_location']"/>
                                        <span t-esc="line['location_suffix']"/>
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">4.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Reports to</td>
                                    <td style="padding: 8px; border: 1px solid #000;"><strong t-esc="line['manager_val']"/></td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">5.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Working Hours</td>
                                    <td style="padding: 8px; border: 1px solid #000;">Shall be eight <strong>(08)</strong> hours a day with one <strong>(01)</strong> hour break and <strong>05</strong> days a week from <strong>Sunday</strong> to <strong>Thursday</strong>.</td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">6.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Overtime</td>
                                    <td style="padding: 8px; border: 1px solid #000;">Not applicable, Time-in-lieu may be arranged with the employee's line supervisor, where this is deemed appropriate.</td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">7.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Probation Period</td>
                                    <td style="padding: 8px; border: 1px solid #000;">The employee shall be subject to a probationary period of three <strong>(03)</strong> months, during which the HOPE has the right to terminate the services of the employee and vice versa.</td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 8px; border: 1px solid #000;">8.</td>
                                    <td style="font-weight: bold; padding: 8px; border: 1px solid #000;">Job Description</td>
                                    <td style="padding: 8px; border: 1px solid #000;">The Employee agrees and confirms the capability and ability to perform the Job Description attached.</td>
                                </tr>
                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 4px; border: 1px solid #000; vertical-align: top;">9.</td>
                                    <td style="font-weight: bold; padding: 4px; border: 1px solid #000; vertical-align: top;">Monthly Gross Salary</td>
                                    <td style="padding: 4px; border: 1px solid #000;">
                                        <p style="margin-bottom: 5px; font-size: 15px;"><t t-esc="line['salary_payment_text']"/></p>
                                        
                                        <table style="width: 95%; margin: 5px auto; border-collapse: collapse; border: 1px solid #000; font-size: 14px;">
                                            <tr style="border: 1px solid #000;">
                                                <td style="padding: 2px 5px; border: 1px solid #000; width: 60%;">Basic Monthly Salary (36.5%)</td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: center; width: 20%;"><t t-esc="line['currency']"/></td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: right; width: 20%;"><t t-esc="'{0:,.2f}'.format(line['salary']['basic'])"/></td>
                                            </tr>
                                            <tr style="border: 1px solid #000;">
                                                <td style="padding: 2px 5px; border: 1px solid #000;">Cost of Living Allowance, COLA (23.5%)</td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: center;"><t t-esc="line['currency']"/></td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: right;"><t t-esc="'{0:,.2f}'.format(line['salary']['cola'])"/></td>
                                            </tr>
                                            <tr style="border: 1px solid #000;">
                                                <td style="padding: 2px 5px; border: 1px solid #000;">Transport Allowance (20%)</td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: center;"><t t-esc="line['currency']"/></td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: right;"><t t-esc="'{0:,.2f}'.format(line['salary']['transport'])"/></td>
                                            </tr>
                                            <tr style="border: 1px solid #000;">
                                                <td style="padding: 2px 5px; border: 1px solid #000;">Housing Allowance (10%)</td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: center;"><t t-esc="line['currency']"/></td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: right;"><t t-esc="'{0:,.2f}'.format(line['salary']['housing'])"/></td>
                                            </tr>
                                            <tr style="border: 1px solid #000;">
                                                <td style="padding: 2px 5px; border: 1px solid #000;">Hazard (10%)</td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: center;"><t t-esc="line['currency']"/></td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: right;"><t t-esc="'{0:,.2f}'.format(line['salary']['hazard'])"/></td>
                                            </tr>
                                            <tr style="border: 1px solid #000; font-weight: bold; background-color: #f2f2f2;">
                                                <td style="padding: 2px 5px; border: 1px solid #000;">Monthly Gross Salary</td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: center;"><t t-esc="line['currency']"/></td>
                                                <td style="padding: 2px 5px; border: 1px solid #000; text-align: right;"><t t-esc="'{0:,.2f}'.format(line['salary']['total_gross'])"/></td>
                                            </tr>
                                        </table>
                                        
                                        <p style="margin-top: 5px; font-size: 14px; line-height: 1.2;">
                                            The monthly salary constitutes full compensation for the entire month, including Fridays and non-working Saturdays. 
                                            Salary payments will be paid between the <strong>27th</strong> and <strong>30th</strong> of each month and will be transferred directly to the employee’s given bank account.
                                        </p>
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 4px; border: 1px solid #000;">10.</td>
                                    <td style="font-weight: bold; padding: 4px; border: 1px solid #000;">Deductions</td>
                                    <td style="padding: 4px; border: 1px solid #000;">
                                        The employee agrees to bear any lawful deductions imposed on the salary (<strong>Social Insurance</strong> – SI and <strong>Personal Income Tax</strong> - PIT) paid by the organization.
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 4px; border: 1px solid #000;">11.</td>
                                    <td style="font-weight: bold; padding: 4px; border: 1px solid #000;">Annual Leave</td>
                                    <td style="padding: 4px; border: 1px solid #000;">
                                        Annual Leave: 08 working days – (02 days per month)The annual leave will be taken during a contract period.
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 4px; border: 1px solid #000;">12.</td>
                                    <td style="font-weight: bold; padding: 4px; border: 1px solid #000;">Benefits &amp; Entitlement </td>
                                    <td style="padding: 4px; border: 1px solid #000;">
                                        SDG 100,000 will be paid before Eid Al Adha's holiday for Muslims or Easter for Christians as a Bonus. 
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 4px; border: 1px solid #000;">13.</td>
                                    <td style="font-weight: bold; padding: 4px; border: 1px solid #000;">Travel Allowance</td>
                                    <td style="padding: 4px; border: 1px solid #000;">
                                        DSA/ Travel Allowance is SDG 20,000 and shall be paid for a field trip with overnight stay and includes food cost. Travel allowance is not paid for site visit, field trip and any other visit that can be completed by one-day trip. In case of the field trip in weekends, the travel allowance shall be paid.
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 4px; border: 1px solid #000;">14.</td>
                                    <td style="font-weight: bold; padding: 4px; border: 1px solid #000;">Termination of Contract</td>
                                    <td style="padding: 4px; border: 1px solid #000;">
                                        Either Party has the right to terminate the contract at any time giving the other party a one month notice.
                                    </td>
                                </tr>

                                <tr style="border: 1px solid #000;">
                                    <td style="text-align: center; padding: 5px; border: 1px solid #000; vertical-align: top;">15.</td>
                                    <td style="font-weight: bold; padding: 5px; border: 1px solid #000; vertical-align: top;">Compliance with Policies and Regulations</td>
                                    <td style="padding: 5px; border: 1px solid #000;">
                                        <ul style="margin: 0; padding-left: 20px; list-style-type: disc;">
                                            <li style="margin-bottom: 5px;">The employees must follow code of conduct and child protection policy in addition to respect of all cultural diversity, ethnic, religious and gender equity including non-discrimination.</li>
                                            <li style="margin-bottom: 5px;">HOPE Policies of are considered as part of this contract.</li>
                                            <li style="margin-bottom: 5px;">Contract conditions and settlement of disputes are subject to Labour Act of 1997.</li>
                                            <li style="margin-bottom: 5px;">The employee has no right to claim any additional entitlements not mentioned in the Law or any other Law unless expressly decided by the HOPE.</li>
                                        </ul>
                                    </td>
                                </tr>
                            </table>
                            <div class="signature_wrapper" style="width: 100%; margin-top: 40px;">
                                <table style="width: 95%; margin: 0 auto; border: none; border-collapse: collapse;">
                                    <tr>
                                        <td style="width: 48%; border: 1px solid #000; padding: 15px; vertical-align: top;">
                                            <p style="text-decoration: underline; font-weight: bold; margin-bottom: 15px; font-size: 17px;">Signed on behalf of (HOPE):</p>
                                            <p style="margin-bottom: 10px;">Name: <strong><t t-esc="line['hq_director']"/></strong></p>
                                            <p style="margin-bottom: 10px;">Title: <strong>Country Director</strong></p>
                                            <p style="margin-bottom: 25px;">Signature: ______________________</p>
                                            <p>Date: ______ / ______ / <t t-esc="datetime.datetime.now().year"/></p>
                                        </td>

                                        <td style="width: 4%;"></td>

                                        <td style="width: 48%; border: 1px solid #000; padding: 15px; vertical-align: top;">
                                            <p style="text-decoration: underline; font-weight: bold; margin-bottom: 15px; font-size: 17px;">Signed by (Employee):</p>
                                            <p style="margin-bottom: 10px;">Name: <strong><t t-esc="line['employee']"/></strong></p>
                                            <p style="margin-bottom: 10px;">ID/Passport: ____________________</p>
                                            <p style="margin-bottom: 25px;">Signature: ______________________</p>
                                            <p>Date: ______ / ______ / <t t-esc="datetime.datetime.now().year"/></p>
                                        </td>
                                    </tr>
                                </table>

                                <div style="text-align: center; margin-top: 25px; width: 100%;">
                                    <div style="display: inline-block; border: 1px solid #ccc; padding: 10px; min-width: 160px; text-align: center;">
                                        <p style="font-size: 12px; color: #666; margin: 0;">Official Organization Stamp</p>
                                        <div style="height: 70px;"></div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div style="page-break-after: always;"></div>
                    <div class="footer text-center">
                        <table width="100%"
                               style="font-family: KacstOne; font-weight: none; border-top:4px solid black">
                            <tr>
                                <td width="100%">

                                    <div style="text-align:left; direction: ltr; line-height: 1.5;">
                                        <p style="font-family: Arial, sans-serif; font-size:14pt; text-align:justify; margin:0 0 0 65px;">
                                            <br/>
                                            Website: www.hopesudan.org, Tel.: +249120023500, E-mail:
                                            hopesudan2015@gmail.com
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="custom_contract_template_paper_format" model="report.paperformat">
        <field name="name">Contract Template Custom</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">25</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="dpi">96</field>
    </record>

    <record id="contract_template_reports" model="ir.actions.report">
        <field name="name">Contract Template</field>
        <field name="model">hr.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hop_hr_payroll.contract_template_reports_info</field>
        <field name="report_file">hop_hr_payroll.contract_template_reports_info_info</field>
        <field name="paperformat_id" ref="hop_hr_payroll.custom_contract_template_paper_format"/>
    </record>
</odoo>