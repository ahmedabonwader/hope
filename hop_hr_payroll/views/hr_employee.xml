<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_inherit_hr_employee_payroll_form" model="ir.ui.view">
            <field name="name">hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="print_staff_information" string="Print Staff Information" type="object" class="oe_highlight"/>
                </xpath>
                <xpath expr="//field[@name='coach_id']" position="attributes">
                    <attribute name="string">Supervisor</attribute>
                </xpath>
                <xpath expr="//field[@name='mobile_phone']" position="attributes">
                    <attribute name="string">Whatsapp Number</attribute>
                </xpath>
                
                <xpath expr="//field[@name='job_id']" position="after">
                    <field name="state_id"/>
                </xpath>

                <xpath expr="//field[@name='bank_account_id']" position="replace">
                    <field name="bank_account_id" domain="[]"/>
                </xpath>
                <xpath expr="//page[@name='personal_information']" position="attributes">
                    <attribute name="string">Staff Private Information</attribute>
                </xpath>
                <xpath expr="//page[@name='personal_information']" position="after">
                    <page name="staff_file" string="Staff File Information">
                        <field name="staff_file_line_ids">
                            <list editable="bottom">
                                <field name="description" placeholder="Specify the document type"/>
                                <field name="document"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_inherit_res_partner_bank_form" model="ir.ui.view">
            <field name="name">res.partner.bank.form</field>
            <field name="model">res.partner.bank</field>
            <field name="inherit_id" ref="account.view_partner_bank_form_inherit_account"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='bank_id']" position="after">
                    <field name="bank_branch" placeholder="PLS Enter The Branc in Arabic"/>
                </xpath>
                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name="bank_name_arabic" placeholder="PLS Enter The Bank Name in Arabic"/>
                    <field name="account_holder_type" widget="radio" options="{'horizontal':true}"/>
                    <field name="holder_arabic_name" placeholder="PLS Enter The Holder Name in Arabic"
                           invisible="account_holder_type == 'employee'"/>
                </xpath>
            </field>
        </record>

        <record id="view_inherit_hr_employee_payroll_search" model="ir.ui.view">
            <field name="name">hr.employee.search</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//searchpanel" position="inside">
                    <field name="state_id" icon="fa-map-marker" enable_counters="1"/>
                </xpath>
            </field>
        </record>

        <record id="view_inherit_hr_employee_payroll_kanban" model="ir.ui.view">
            <field name="name">hr.employee.kanban.inherit.state</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <div>
                        <span class="o_text_overflow">
                            <field name="state_id"/>
                        </span>
                    </div>
                </xpath>
            </field>
        </record>


        <record id="view_hr_state_location_tree" model="ir.ui.view">
            <field name="name">hr.state.location.list</field>
            <field name="model">hr.state.location</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>

        <record id="view_hr_state_location_form" model="ir.ui.view">
            <field name="name">hr.state.location.form</field>
            <field name="model">hr.state.location</field>
            <field name="arch" type="xml">
                <form string="Activity">
                    <sheet>
                         <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="code"/>
                            </group>
                        </group>
                    </sheet>
                    <!-- Chatter -->
                    <chatter reload_on_attachment="True"/>
                </form>
            </field>
        </record>

        <record id="view_hr_state_location_search" model="ir.ui.view">
            <field name="name">hr.state.location.search</field>
            <field name="model">hr.state.location</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Patient Name"/>
                </search>
            </field>
        </record>

        <record id="action_hr_state_location" model="ir.actions.act_window">
            <field name="name">Hr State Location</field>
            <field name="res_model">hr.state.location</field>
            <field name="view_mode">list,form,search</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your State Location !
                </p>
            </field>
        </record>

        <menuitem id="menu_hr_state_location"
                  name="State Location"
                  parent="hr.menu_hr_root"
                  action="hop_hr_payroll.action_hr_state_location"
                  sequence="12"/>

    </data>
</odoo>