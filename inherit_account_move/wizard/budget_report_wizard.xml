<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_budget_wizard_report_form" model="ir.ui.view">
            <field name="name">Budget Report Wizard</field>
            <field name="model">budget.report.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Budget Report">
                    <group>
                        <group>
                            <field name="budget_state"/>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="budget_id" options="{'no_quick_create': True, 'no_create_edit' : True}"
                                   domain="[('state', '=', budget_state)]"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print" string="Print" type="object" class="oe_highlight"/>
                        <button string="Export to Excel" type="object" name="action_print_excel" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_budget_wizard_report_action" model="ir.actions.act_window">
            <field name="name">Budget Report</field>
            <field name="res_model">budget.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>