<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_authorized_wizard_form" model="ir.ui.view">
        <field name="name">authorized.wizard.form</field>
        <field name="model">authorized.wizard</field>
        <field name="arch" type="xml">
            <form string="Void Check">
                <group>
                    <group>
                        <field name="user_id" readonly="0"/>
                    </group>

                    <group>
                        <footer>
                            <button name="action_validate" string="Applay" type="object" class="btn-primary"
                                    data-hotkey="q" />

                            <button special="cancel" data-hotkey="z" string="Discard" class="btn-secondary"/>
                        </footer>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!--    menu action-->
    <record id="view_authorized_wizard_wizard_action" model="ir.actions.act_window">
        <field name="name">Authorized Wizard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">authorized.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>