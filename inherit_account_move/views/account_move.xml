    <record id="inherit_view_account_move_search" model="ir.ui.view">
        <field name="name">account.move</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_bill_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='to_check']" position="before">
                <filter name="project_id" string="Projects" context="{'group_by':'project_id'}"/>
                <separator/>
                <filter name="active_projects" string="Active Projects"
                        domain="[('project_id.state', '=', 'running')]"/>
                <separator/>
            </xpath>
            <xpath expr="//search" position="inside">
                <searchpanel>
                    <field name="state" icon="fa-users" string="State" enable_counters="1"/>
                    <field name="payment_state" icon="fa-users" string="Payment status" enable_counters="1"/>
                    <field name="branch_id" icon="fa-users" string="Branches" enable_counters="1"/>
                </searchpanel>
            </xpath>
        </field>
    </record>

    <!--    <record id="account.action_move_in_invoice_type" model="ir.actions.act_window">-->
    <!--        <field name="context">{'group_by': 'project_id'}</field>-->
