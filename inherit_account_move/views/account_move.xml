    <record id="account.action_move_in_invoice" model="ir.actions.act_window">
        <field name="context">{'search_default_in_invoice': 1,'search_default_project_id': 1,
            'search_default_active_projects': 1, 'default_move_type': 'in_invoice', 'display_account_trust': True}
        </field>
    </record>

    <record id="oms_account_move_line_inherit_list" model="ir.ui.view">
        <field name="name">account.move.line</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_id']" position="after">
                <field name="project_id" invisible="move_type != 'entry'"/>
                <!--                <button name="get_project_id" string="Get Project" type="object" class="oe_highlight" invisible="move_type != 'entry'"/>-->
            </xpath>

        </field>
    </record>
    
    <record id="view_account_move_search_inherit_bank_ref" model="ir.ui.view">
        <field name="name">account.move.search.inherit.bank.transfer.ref</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <!-- إضافة الحقل داخل السيرش -->
            <xpath expr="//search" position="inside">
                <field name="bank_transfer_ref" string="Bank Transfer Reference"/>
            </xpath>

        </field>
    </record>

