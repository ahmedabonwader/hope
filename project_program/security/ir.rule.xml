<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0"> 

        <record id="project_administrator_rule" model="ir.rule">
            <field name="name">Project Admins - See All Project</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project_program.group_project_admin'))]"/>
        </record>

        <record id="project_doner_project_user_rule" model="ir.rule">
            <field name="name">Project Donor - Strict Restriction</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[('id', 'in', user.project_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('project_program.group_project_doner'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="project.project_public_members_rule" model="ir.rule">
            <field name="groups" eval="[(3, ref('project_program.group_project_doner'))]"/>
        </record>

        <record id="project.project_project_rule_portal" model="ir.rule">
            <field name="groups" eval="[(3, ref('project_program.group_project_doner'))]"/>
        </record>

    </data>
</odoo>