<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Security For Project Model -->
        <record model="ir.module.category" id="module_category_organization_management_system_project">
            <field name="name">Organization Management System Project</field>
            <field name="description">Category For Organization Management System Project</field>
        </record>

        <record id="group_project_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="users" eval="[(4, ref('base.user_root')),(4, ref('base.user_admin'))]"/>
            <field name="category_id" ref="module_category_organization_management_system_project"/>
        </record>

        <record id="group_project_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_organization_management_system_project"/>
        </record>
    
        <record id="group_project_doner" model="res.groups">
            <field name="name">Doner</field>
            <field name="category_id" ref="module_category_organization_management_system_project"/>
        </record>

    </data>

</odoo>