<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Form View -->
    <record id="project_project_view_form_inherit" model="ir.ui.view">
        <field name="name">project.project.form.inherit.budget</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Budget Information" name="budget_info">
                    <group>
                        <field name="total_expected_budget" widget="monetary"/>
                        <field name="curr_id"/>
                        <field name="subtasks_expected_budget" widget="monetary" readonly="1"/>
                    </group>
                </page>
                <page string="Followup Report" name="followup_report">
                    <group>
                        <field name="followup_template_id"/>
                    </group>
                    <field name="followup_report" widget="html"/>
                </page>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="project_code"></field>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="string">Donor</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="string">Sectors</attribute>
            </xpath>
            <notebook position="inside">
            <page string="Project Staff">
                <field name="staff_line_ids">
                    <list editable="bottom">
                        <field name="line_number"/>
                        <field name="emp_id"/>
                        <field name="department"/>
                        <field name="note"/>
                    </list>
                </field>
            </page>
        </notebook>
        </field>
    
    </record>

    <!-- Inherit Tree View -->
    <record id="project_project_view_tree_inherit" model="ir.ui.view">
        <field name="name">project.project.tree.inherit.budget</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="total_expected_budget" sum="Total" widget="monetary"/>
                <field name="subtasks_expected_budget" sum="Total Tasks" widget="monetary"/>
            </field>
        </field>
    </record>

    <!-- Inherit Kanban View -->
    <record id="project_project_view_kanban_inherit" model="ir.ui.view">
        <field name="name">project.project.kanban.inherit.budget</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_project_kanban_boxes')]" position="inside">
                <div class="o_project_kanban_box">
                    <div class="o_value">
                        <field name="total_expected_budget" widget="monetary"/>
                    </div>
                    <div class="o_label">Expected Budget</div>
                </div>
                <div class="o_project_kanban_box">
                    <div class="o_value">
                        <field name="subtasks_expected_budget" widget="monetary"/>
                    </div>
                    <div class="o_label">Tasks Budget</div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="project_project_view_search_inherit" model="ir.ui.view">
        <field name="name">project.project.search.inherit.budget</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_project_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='tags']" position="after">
                <filter name="partner_id" string="Donor" context="{'group_by':'partner_id'}"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="string">Sectors</attribute>
            </xpath>
            <xpath expr="//filter[@name='tags']" position="attributes">
                <attribute name="string">Sectors</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="string">Donor</attribute>
            </xpath>
        </field>
    </record>

    <record id="project.open_view_project_all" model="ir.actions.act_window">
        <field name="context">{'search_default_own_projects': 1, 'display_milestone_deadline': True}</field>
    </record>
    <record id="project.open_view_project_all_config_group_stage" model="ir.actions.act_window">
        <field name="context">{'search_default_own_projects': 1, 'display_milestone_deadline': True}</field>
    </record>

    <record id="project.open_view_project_all_group_stage" model="ir.actions.act_window">
        <field name="context">{'search_default_own_projects': 1, 'search_default_group_stage': 1 , 'display_milestone_deadline': True}</field>
    </record>
     <record id="project.open_view_project_all_config" model="ir.actions.act_window">
        <field name="context">{'search_default_own_projects': 1, 'search_default_group_stage': 1 , 'display_milestone_deadline': True}</field>
    </record>
</odoo>