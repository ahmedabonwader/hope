<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> <record id="project_purchase_request_administrator_rule" model="ir.rule">
            <field name="name">Project Purchase Request Admins - See All Project</field>
            <field name="model_id" ref="project_purchase_request.model_project_purchase_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project_purchase_request.group_purchase_request_manager'))]"/>
        </record>

        <record id="project_purchase_request_doner_project_rule" model="ir.rule">
            <field name="name">Project Purchase Request Doner - See Only Their Projects or All if Empty</field>
            <field name="model_id" ref="project_purchase_request.model_project_purchase_request"/>
            <field name="domain_force">[('project_id', 'in', user.project_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('project_purchase_request.group_purchase_request_donor'))]"/>
        </record>

    </data>
</odoo>