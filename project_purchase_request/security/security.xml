<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="ir.module.category" id="module_category_purchase_request">
            <field name="name">Purchase Request</field>
            <field name="description">User access level for Project Purchase Request module</field>
            <field name="sequence">20</field>
        </record>
           <!-- 1. مستوى المستخدم العادي (القراءة فقط) -->
        <record id="group_purchase_request_user" model="res.groups">
            <field name="name">مستخدم طلبات الشراء</field>
            <field name="category_id" ref="module_category_purchase_request"/>
            <field name="comment">صلاحيات عرض طلبات الشراء فقط</field>
        </record>

        <!-- 2. مستوى المسؤول (إنشاء وتعديل) -->
        <record id="group_purchase_request_officer" model="res.groups">
            <field name="name">مسؤول طلبات الشراء</field>
            <field name="category_id" ref="module_category_purchase_request"/>
            <field name="implied_ids" eval="[(4, ref('group_purchase_request_user'))]"/>
            <field name="comment">صلاحيات إنشاء وتعديل طلبات الشراء</field>
        </record>

        <record id="group_purchase_request_finance" model="res.groups">
            <field name="name">محاسب طلبات الشراء</field>
            <field name="category_id" ref="module_category_purchase_request"/>
            <field name="implied_ids" eval="[(4, ref('group_purchase_request_user'))]"/>
            <field name="comment">صلاحيات إنشاء وتعديل طلبات الشراء</field>
        </record>

        <record id="group_purchase_request_procurement" model="res.groups">
            <field name="name">قسم المشتروات</field>
            <field name="category_id" ref="module_category_purchase_request"/>
            <field name="implied_ids" eval="[(4, ref('group_purchase_request_user'))]"/>
            <field name="comment">صلاحيات إنشاء وتعديل طلبات الشراء</field>
        </record>

        <!-- 3. مستوى المدير (كامل الصلاحيات) -->
        <record id="group_purchase_request_manager" model="res.groups">
            <field name="name">مدير طلبات الشراء</field>
            <field name="category_id" ref="module_category_purchase_request"/>
            <field name="implied_ids" eval="[(4, ref('group_purchase_request_officer'))]"/>
            <field name="comment">صلاحيات كاملة بما فيها الموافقة والحذف</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_purchase_request_donor" model="res.groups">
            <field name="name">المانح - طلبات الشراء</field>
            <field name="category_id" ref="module_category_purchase_request"/>
            <field name="comment">صلاحيات الاطلاع على طلبات الشراء الخاصة بمشاريعه فقط</field>
        </record>
    </data>
</odoo>