<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_old_data_wizard_form" model="ir.ui.view">
            <field name="name">Old Data wizard</field>
            <field name="model">old.data.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Budget Report">
                    <group>
                        <group>
                            <field name="model"/>
                        </group>
                    </group>
                    <footer>
                        <button name="get_old_data" string="Validate" type="object" class="oe_highlight"/>
                        <button name="action_update" string="Update" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_old_data_wizard_action" model="ir.actions.act_window">
            <field name="name">Get Old Data</field>
            <field name="res_model">old.data.wizard</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>