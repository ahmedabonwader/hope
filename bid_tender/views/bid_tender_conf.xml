<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_oms_bid_tender_conf_list" model="ir.ui.view">
        <field name="name">oms.bid.tender.conf.list</field>
        <field name="model">oms.bid.tender.conf</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="operation_type"/>
                <field name="amount"/>
                <field name="currency_id"/>
            </list>
        </field>
    </record>

    <record id="view_oms_bid_tender_conf_form" model="ir.ui.view">
        <field name="name">oms.bid.tender.conf.form</field>
        <field name="model">oms.bid.tender.conf</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="operation_type"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter -->
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div> -->
            </form>
        </field>
    </record>
    <record id="view_oms_bid_tender_conf_search" model="ir.ui.view">
        <field name="name">oms.bid.tender.conf.search</field>
        <field name="model">oms.bid.tender.conf</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_oms_bid_tender_conf" model="ir.actions.act_window">
        <field name="name">Bid/Tender Configuration</field>
        <field name="res_model">oms.bid.tender.conf</field>
        <field name="view_mode">list,form,search</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your Bid/Tender Configuration !
            </p>
        </field>
    </record>


</odoo>