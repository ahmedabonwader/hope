<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_certificate_completion_list" model="ir.ui.view">
        <field name="name">certificate.completion.list</field>
        <field name="model">certificate.completion</field>
        <field name="arch" type="xml">
            <list
                    decoration-success="state == 'comlete'"
                    decoration-warning="state == 'confirm'"
                    decoration-info="state == 'draft'">
                <field name="ref"/>
                <field name="purchase_order"/>
                <field name="prs"/>
                <field name="suppliers"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="user_id"/>
                <field name="branch_id"/>
                <field name="state"
                       decoration-success="state == 'comlete'"
                       decoration-warning="state == 'confirm'"
                       decoration-info="state == 'draft'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_certificate_completion_form" model="ir.ui.view">
        <field name="name">certificate.completion.form</field>
        <field name="model">certificate.completion</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" data-hotkey="k"
                            class="oe_highlight" invisible="state != 'draft'"
                            groups="bid_tender.group_oms_administrator,bid_tender.group_bid_tender_procurement"/>

                    <button name="action_approve" string="Approve" type="object" data-hotkey="k"
                            class="oe_highlight" invisible="state != 'confirm'"
                            groups="bid_tender.group_oms_administrator,bid_tender.group_bid_tender_approve"/>

                    <button name="action_reset_to_draft" string="Draft" type="object" data-hotkey="k"
                            invisible="state != 'confirm'"
                            groups="bid_tender.group_oms_administrator,bid_tender.group_bid_tender_approve"/>

                    <button name="action_print_certificate_completion_report" string="Print Certificate" type="object" data-hotkey="k"
                            invisible="state != 'complete'" class="btn-warning"
                            />

                    <field name="state" widget="statusbar" nolabel="1"/>
                    <!-- <field name="state" widget="statusbar" nolabel="1" options="{'clickable': '1'}"/> -->
                </header>
                <sheet>
                    <div class="oe_titel">
                        <h4>
                            <field name="ref" readonly="1"/>
                        </h4>
                    </div>

                    <group>
                        <group>
                            <field name="purchase_order" options="{'no_quick_create': True, 'no_create_edit' : True}" readonly="1"/>
                            <field name="prs" options="{'no_quick_create': True, 'no_create_edit' : True}" readonly="1"/>
                            <field name="suppliers" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="time" readonly="1"/>
                            <field name="prepared_job_title" readonly="1" invisible="1"/>
                            <field name="approved_job_title" readonly="1" invisible="1"/>
                            <field name="project_id" options="{'no_quick_create': True, 'no_create_edit' : True}" readonly="1"/>
                            <field name="task_id" options="{'no_quick_create': True, 'no_create_edit' : True}" widget="many2many_tags" readonly="1"/>
                            <field name="branch_id" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Certificate Details">
                            <group>
                                <field name="note"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_attachment="True"/>
            </form>
        </field>
    </record>

    <record id="view_certificate_completion_search" model="ir.ui.view">
        <field name="name">certificate.completion.search</field>
        <field name="model">certificate.completion</field>
        <field name="arch" type="xml">
            <search>
                <field name="ref"/>
                <field name="project_id"/>
                <field name="prs"/>
                <field name="suppliers"/>
                <!-- <searchpanel>
                    <field name="state" icon="fa-users" string="State" enable_counters="1"/>
                    <field name="branch_id" icon="fa-users" string="Branches" enable_counters="1"/>
                </searchpanel> -->
            </search>
        </field>
    </record>

    <record id="action_certificate_completion" model="ir.actions.act_window">
        <field name="name">Certificate Completion</field>
        <field name="res_model">certificate.completion</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Certificate Completion !
            </p>
        </field>
    </record>

</odoo>