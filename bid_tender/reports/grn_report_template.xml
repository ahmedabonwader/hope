<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="print_grn_reports_info">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" style="margin: 0 30px; position: relative; font-family: KacstOne; color: #003366;">
                    <t t-if="data and len(data) > 0 and data[0].get('report_logo')">
                        <div style="position: absolute; top: 10px; left: 30px; z-index: 1;">
                            <img t-attf-src="data:image/png;base64,{{ data[0]['report_logo'] }}"
                                style="max-height: 80px; max-width: 150px;"/>
                        </div>
                    </t>

                    <div style="text-align: center; margin-top: 20px;">
                        <t t-if="data and len(data) > 0">
                            <h3 t-esc="data[0]['company_name']" style="text-decoration: underline;"/>
                        </t>
                        <h3 style="text-decoration: underline;">Supply Chain Management - Warehouse</h3>
                        <h3 style="text-decoration: underline;">Good Received Note (GRN)</h3>
                    </div>

                    <t t-if="data and len(data) > 0 and data[0].get('report_logo')">
                        <div style="position: absolute; top: 10px; right: 30px; z-index: 1;">
                            <img t-attf-src="data:image/png;base64,{{ data[0]['report_logo'] }}"
                                style="max-height: 80px; max-width: 150px;"/>
                        </div>
                    </t>
                </div>
                <br/>
                <br/>
                <div style="border: 1px solid #000; padding: 5px; background-color: #f0f0f0; margin-bottom: 10px;">
                    <div style="text-align: left; font-weight: bold; margin-bottom: 5px;">
                        Project Name :
                    </div>
                    <h3 t-esc="data[0]['project'] or 'Project Name'"
                        style="margin: 0; text-align: center; color: #000;"/>
                </div>

                <table style="width: 100%; border-collapse: collapse; margin-bottom: 10px;" dir="ltr">
                    <tr>
                        <td style="width: 50%; padding: 3px; border: 1px solid #000; text-align:left;">
                            <strong>PR No :</strong>
                            <t t-esc="data[0]['prs_id']"/>
                        </td>
                        <td style="width: 50%; padding: 3px; border: 1px solid #000; text-align:left;">
                            <strong>PO NO :</strong>
                            <t t-esc="data[0]['po']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 3px; border: 1px solid #000; text-align:left;">
                            <strong>Supplier Name :</strong>
                            <t t-esc="data[0]['supplier']"/>
                        </td>
                        <td style="padding: 3px; border: 1px solid #000; text-align:left;">
                            <strong>Supplier Reference :</strong>
                            <t t-esc="data[0]['supplier_ref']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 3px; border: 1px solid #000; text-align:left;">
                            <strong>Received Date :</strong>
                            <t t-esc="data[0]['date']"/>
                        </td>
                        <td style="padding: 3px; border: 1px solid #000; text-align:left;">
                            <strong>Received Location :</strong>
                            <t t-esc="data[0]['received_location']"/>
                        </td>
                    </tr>
                </table>
                <br/>
                <div style="margin-top: 5px;">
                    <h3 style="margin: 0; text-align: left; padding-bottom: 5px;">Details :</h3>
                    <table style="width: 100%; font-size: 14px; border-collapse: collapse; border: 2px solid black; text-align: center;" dir="ltr">
                        <thead>
                            <tr style="background-color: #e2e2e2; border-bottom: 2px solid black;">
                                <th style="border: 1px solid black; padding: 8px; font-weight: bold;">Description</th>
                                <th style="border: 1px solid black; padding: 8px; font-weight: bold;">Unit</th>
                                <th style="border: 1px solid black; padding: 8px; font-weight: bold;">Demand</th>
                                <th style="border: 1px solid black; padding: 8px; font-weight: bold;">Received</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="line_data" t-as="line">
                                <tr>
                                    <td style="border: 1px solid black; padding: 6px; text-align: center;">
                                        <t t-esc="line['product_id']"/>
                                    </td>
                                    <td style="border: 1px solid black; padding: 6px;">
                                        <t t-esc="line['unit']"/>
                                    </td>
                                    <td style="border: 1px solid black; padding: 6px;">
                                        <t t-esc="line['product_uom_qty']"/>
                                    </td>
                                    <td style="border: 1px solid black; padding: 6px;">
                                        <t t-esc="line['quantity']"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
                <br/>
                <div class="sec_hedar_data" style="text-align:right; width:100%;">
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;" dir="ltr">
                        <tr>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Goods Deliverd By :</strong>
                                <t t-esc="data[0]['delivered_by']"/>
                            </td>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Goods Received By :</strong>
                                <t t-esc="data[0]['received_by']"/>
                            </td>
                            
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Title :</strong>
                                <t t-esc="data[0]['title']"/>
                            </td>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Title :</strong>
                                <t t-esc="data[0]['received_title']"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Signature :</strong>
                                <!-- <t t-esc="data[0]['title']"/> -->
                            </td>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Signature :</strong>
                                <!-- <img t-if="data['received_signature']" t-att-src="'data:image/png;base64,%s' % data['received_signature']" style="max-height: 50px;" /> -->
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Date :</strong>
                                <t t-esc="data[0]['date_de']"/>
                            </td>
                            <td style="width: 50%; padding: 5px; border: 1px solid #000; text-align:left;">
                                <strong>Date :</strong>
                                <t t-esc="data[0]['date']"/>
                            </td>
                        </tr>
                    </table>
                </div>
                <div style="page-break-after: always;"></div>
                <div class="footer text-center">
                    <table width="100%"
                            style="font-family: KacstOne; font-weight: none; border-top:4px solid black">
                        <tr>
                            <td width="100%">
                                <div style="text-align:left; direction: ltr; line-height: 1.5;">
                                    <p style="font-family: Arial, sans-serif; font-size:14pt; text-align:justify; margin:0 0 0 65px;">
                                        <br/>
                                        Website: www.hopesudan.org, Tel.: +249120023500, E-mail:
                                        hopesudan2015@gmail.com
                                    </p>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="custom_grn_report_paper_format" model="report.paperformat">
        <field name="name">GRN Report</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">25</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="dpi">96</field>
    </record>

    <record id="print_grn_reports" model="ir.actions.report">
        <field name="name">GRN Report</field>
        <field name="model">qrn.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bid_tender.print_grn_reports_info</field>
        <field name="report_file">bid_tender.print_grn_reports_info</field>
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>  <!-- الصحيح -->
        <field name="paperformat_id" ref="bid_tender.custom_grn_report_paper_format"/>
    </record>
</odoo>