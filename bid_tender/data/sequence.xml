<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_oms_tender_special" model="ir.sequence">
            <field name="name">OMS Special Tender Sequence</field>
            <field name="code">oms.tender.special</field>
            <field name="prefix">HOPE-TENDER/%(year)s/</field>
            <field name="padding">2</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_certificate_completion" model="ir.sequence">
            <field name="name">Certificate Completion</field>
            <field name="code">certificate.completion</field>
            <field name="prefix">Certificate of Completion/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>