<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custody Tree View -->
    <record id="view_custody_list" model="ir.ui.view">
        <field name="name">account.journal.custody.tree</field>
        <field name="model">account.journal</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Custody Journals" decoration-info="custody_status=='draft'" 
                  decoration-success="custody_status=='active'" 
                  decoration-warning="custody_status=='suspended'"
                  decoration-danger="custody_status=='closed'">
                <field name="name" string="Custody"/>
                <field name="code"/>
                <field name="custody_employee_id"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="balance"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="custody_status" widget="badge" decoration-info="custody_status=='draft'" decoration-success="custody_status=='active'" decoration-warning="custody_status=='suspended'" decoration-danger="custody_status=='closed'"/>
            </list>
        </field>
    </record>

    <!-- Custody Form View -->
    <record id="view_custody_form" model="ir.ui.view">
        <field name="name">account.journal.custody.form</field>
        <field name="model">account.journal</field>
        <field name="arch" type="xml">
            <form string="Custody">
                <header>
                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reset to Draft"
                            class="btn-secondary"
                            invisible="custody_status == 'draft'"/>
                    <button name="action_activate_custody"
                            type="object"
                            string="Activate"
                            class="btn-primary"
                            invisible="custody_status != 'draft'"/>
                    <button name="action_suspend_custody"
                            type="object"
                            string="Suspend" 
                            class="btn-warning"
                            invisible="custody_status != 'active'"/>
                    <button name="action_close_custody"
                            type="object"
                            string="Close"
                            class="btn-danger"
                            invisible="custody_status in ['closed', 'draft']"/>
                    <field name="custody_status" widget="statusbar" statusbar_visible="draft,active,suspended,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="action" name="240" icon="fa-book" context="{'search_default_journal_id':id}">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="balance"/>
                                </span>
                                <span class="o_stat_text">
                                    Balance
                                </span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Suspended" bg_color="text-bg-warning" invisible="active"/>
                    <widget name="web_ribbon" title="Closed" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name" readonly="custody_status != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" readonly="custody_status != 'draft'"/>
                            <field name="default_account_id" readonly="custody_status != 'draft'"/>
                            <field name="type" default="bank" readonly="custody_status != 'draft'"/>
                            <field name="currency_id" readonly="custody_status != 'draft'"/> 
                        </group>
                        <group>
                            <field name="custody_employee_id" required="1" readonly="custody_status  != 'draft'"/>
                            <field name="user_ids" widget="many2many_tags" options="{'no_create': True}" readonly="custody_status != 'draft'"/>
                            <field name="company_id" readonly="custody_status != 'draft'"/>
                        </group>
                    </group>
                </sheet>
                <chatter reload_on_attachment="True"/>
            </form>
        </field>
    </record>

    <!-- Custody Search View -->
    <record id="view_custody_search" model="ir.ui.view">
        <field name="name">account.journal.custody.search</field>
        <field name="model">account.journal</field>
        <field name="arch" type="xml">
            <search string="Search Custody">
                <field name="name" string="Journal"/>
                <field name="code"/>
                <field name="custody_employee_id"/>
                <!-- <field name="user_ids"/> -->
                <separator/>
                <filter string="Custody Journals" name="is_custody" domain="[('is_custody', '=', True)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('custody_status', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('custody_status', '=', 'active')]"/>
                <filter string="Suspended" name="suspended" domain="[('custody_status', '=', 'suspended')]"/>
                <filter string="Closed" name="closed" domain="[('custody_status', '=', 'closed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'custody_employee_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'custody_status'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

