    <!-- Action for Custody Journals -->
    <record id="action_custody" model="ir.actions.act_window">
        <field name="name">Custody Journals</field>
        <field name="res_model">account.journal</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_custody', '=', True)]</field>
        <field name="context">{'default_is_custody': True, 'default_type': 'bank'}</field>
        <field name="search_view_id" ref="custody.view_custody_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('custody.view_custody_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('custody.view_custody_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Custody Journal
            </p>
            <p>
                Custody journals are used to manage and track custody transactions
                with employees, including balance tracking and limits.
            </p>
        </field>
    </record>
    
</odoo> 