<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="budget_finance_report_info">
            <t t-call="web.basic_layout">
                <div class="page">
                    <div style="text-align: center; font-family: KacstOne; color: #003366; margin-top: 20px;">
                        <t t-if="header and len(header) > 0">
                            <h3 t-esc="header[0]['company_name']" style="text-decoration: underline;"/>
                        </t>
                        <h3 style="text-decoration: underline;">Financial Report</h3>
                        <t t-if="header and len(header) > 0">
                            <h4 t-esc="header[0]['project_title']" style="text-decoration: underline;"/>
                        </t>
                    </div>
                    <br/>
                    <div class="sec_hedar_data" style="text-align:right; width:100%;">
                        <table style="border: none; width:100%;" dir="rtl">
                            <tr>
                                <td style="text-align:left; width:50%; padding-left:30px;">
                                    <t t-if="header and len(header) > 0 and header[0].get('quarter')">
                                        <span style="color: #FFBF00; font-weight: bold;">Quarter :</span>
                                        <span style="color: #000000; font-weight: 500;">
                                            <t t-esc="header[0]['quarter']"/>
                                        </span>
                                    </t>
                                </td>
                                <td style="text-align:right; width:50%; padding-right:30px;">
                                    <t t-if="header and len(header) > 0">
                                        <span style="color: #FFBF00; font-weight: bold;">Project Period:</span>
                                        <span style="color: #000000; font-weight: 500;">
                                            <t t-esc="header[0]['start_date'] if header[0]['start_date'] else ''"/>
                                            &#160;&#160;To&#160;&#160;
                                            <t t-esc="header[0]['end_date'] if header[0]['end_date'] else ''"/>
                                        </span>
                                    </t>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <br/>
                    <div style="margin-top: 5px;">
                        <t t-if="summary">
                            <table class="table table-sm" dir="ltr"
                                style="width: 100%; table-layout: fixed; font-size: 11px; border-collapse: collapse; border: 1px solid black;">
                                <thead>
                                    <tr style="border-bottom: 2px solid #003366; background-color: #f0f0f0;">
                                        <th style="width:18%; border:1px solid black; padding:8px; text-align:center;">Budget Line</th>
                                        <th style="width:22%; border:1px solid black; padding:8px; text-align:center;">Budget Description</th>
                                        <th style="width:7%; border:1px solid black; padding:8px; text-align:center;">Total Budget</th>

                                        <t t-foreach="selected_quarters" t-as="quarter">
                                            <th style="width:7%; border:1px solid black; padding:8px; text-align:center;">
                                                Installment <t t-if="not is_single_quarter" t-esc="quarter"/>
                                            </th>
                                            <th style="width:7%; border:1px solid black; padding:8px; text-align:center;">
                                                Actual Expenditure <t t-if="not is_single_quarter" t-esc="quarter"/>
                                            </th>
                                        </t>

                                        <th style="width:7%; border:1px solid black; padding:8px; text-align:center;">Balance</th>
                                        <th style="width:5%; border:1px solid black; padding:8px; text-align:center;">% Spent</th>
                                        
                                        <t t-if="has_more_details">
                                            <th style="width:10%; border:1px solid black; padding:8px; text-align:center;">State</th>
                                            <th style="width:10%; border:1px solid black; padding:8px; text-align:center;">Budget Account</th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="processed_lines" t-value="[]"/>
                                    <t t-foreach="data" t-as="line_item">
                                        <t t-if="line_item['budget_line'] not in processed_lines">
                                            <t t-set="processed_lines" t-value="processed_lines + [line_item['budget_line']]"/>
                                            <t t-set="line_quarters_data" t-value="[item for item in data if item['budget_line'] == line_item['budget_line']]"/>
                                            
                                            <tr>
                                                <td style="text-align:center; border:1px solid black;">
                                                    <t t-esc="line_item.get('budget_line', '')"/>
                                                </td>
                                                <td style="text-align:center; border:1px solid black;">
                                                    <t t-esc="line_item.get('description', '')"/>
                                                </td>
                                                <td style="text-align:center; border:1px solid black; direction: ltr;">
                                                    <t t-esc="line_item.get('total_budget', 0)" t-options="{'widget':'float','precision':0}"/>
                                                    <t t-esc="line_item.get('currency')"/>
                                                </td>

                                                <t t-foreach="selected_quarters" t-as="quarter">
                                                    <t t-set="q_data" t-value="[item for item in line_quarters_data if item['quarter_name'] == quarter]"/>
                                                    <td style="text-align:center; border:1px solid black; direction: ltr;">
                                                        <t t-if="q_data" t-esc="q_data[0]['installment']" t-options="{'widget':'float','precision':0}"/>
                                                        <t t-else="">0</t> <t t-esc="line_item.get('currency')"/>
                                                    </td>
                                                    <td style="text-align:center; border:1px solid black; direction: ltr;">
                                                        <t t-if="q_data" t-esc="q_data[0]['actual_expenditure']" t-options="{'widget':'float','precision':0}"/>
                                                        <t t-else="">0</t> <t t-esc="line_item.get('currency')"/>
                                                    </td>
                                                </t>

                                                <td style="text-align:center; border:1px solid black; direction: ltr;">
                                                    <t t-set="total_actual" t-value="sum(item['actual_expenditure'] for item in line_quarters_data)"/>
                                                    <t t-esc="(line_item['total_budget'] or 0) - total_actual" t-options="{'widget':'float','precision':0}"/>
                                                    <t t-esc="line_item.get('currency')"/>
                                                </td>
                                                <td style="text-align:center; border:1px solid black;">
                                                    <t t-esc="'%.2f' % (line_item['spent'] or 0)"/>%
                                                </td>
                                                
                                                <t t-if="has_more_details">
                                                    <td style="text-align:center; border:1px solid black;"><t t-esc="line_item.get('state', '')"/></td>
                                                    <td style="text-align:center; border:1px solid black;"><t t-esc="line_item.get('budget_account', '')"/></td>
                                                </t>
                                            </tr>
                                        </t>
                                    </t>

                                    <tr style="font-weight: bold; background-color: #e0e0e0;">
                                        <td colspan="2" style="text-align:center; border:1px solid black;">Total</td>
                                        <td style="text-align:center; border:1px solid black; direction: ltr;">
                                            <t t-esc="summary.get('sum_total_budget', 0)" t-options="{'widget':'float','precision':0}"/>
                                            <t t-if="data" t-esc="data[0].get('currency')"/>
                                        </td>

                                        <t t-foreach="selected_quarters" t-as="quarter">
                                            <td style="text-align:center; border:1px solid black; direction: ltr;">
                                                <t t-esc="sum(item['installment'] for item in data if item['quarter_name'] == quarter)" t-options="{'widget':'float','precision':0}"/>
                                                <t t-if="data" t-esc="data[0].get('currency')"/>
                                            </td>
                                            <td style="text-align:center; border:1px solid black; direction: ltr;">
                                                <t t-esc="sum(item['actual_expenditure'] for item in data if item['quarter_name'] == quarter)" t-options="{'widget':'float','precision':0}"/>
                                                <t t-if="data" t-esc="data[0].get('currency')"/>
                                            </td>
                                        </t>

                                        <td style="text-align:center; border:1px solid black; direction: ltr;">
                                            <t t-esc="summary.get('sum_balance', 0)" t-options="{'widget':'float','precision':0}"/>
                                            <t t-if="data" t-esc="data[0].get('currency')"/>
                                        </td>
                                        <td style="text-align:center; border:1px solid black;">
                                            <t t-esc="'%.2f' % (summary.get('spent_percent') or 0)"/>%
                                        </td>
                                        <t t-if="has_more_details"><td colspan="2" style="border:1px solid black;"></td></t>
                                    </tr>
                                </tbody>
                            </table>
                        </t>

                        <t t-if="header and len(header) > 0">
                            <t t-set="h" t-value="header[0]"/>
                            <table class="table table-borderless mt-4" style="font-size: 11px; width: 100%; page-break-inside: avoid;">
                                <thead>
                                    <tr style="border-bottom: 2px solid #003366;">
                                        <th style="width: 20%;">Position</th>
                                        <th style="width: 20%;">Name</th>
                                        <th style="width: 20%;">Job Title</th>
                                        <th style="width: 25%;">Signature</th>
                                        <th style="width: 15%;">Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Prepared by</td>
                                        <td><span t-esc="h['prepared']"/></td>
                                        <td><span t-esc="h['prepared_job_title']"/></td>
                                        <td><img t-if="h['prepared_signature']" t-att-src="'data:image/png;base64,%s' % h['prepared_signature']" style="max-height: 45px;" /></td>
                                        <td><span t-esc="h['prepared_date']"/></td>
                                    </tr>
                                    <tr>
                                        <td>Reviewed by</td>
                                        <td><span t-esc="h['reviewed_by']"/></td>
                                        <td><span t-esc="h['reviewed_job_title']"/></td>
                                        <td><img t-if="h['signature_reviewed']" t-att-src="'data:image/png;base64,%s' % h['signature_reviewed']" style="max-height: 45px;" /></td>
                                        <td><span t-esc="h['validate_date']"/></td>
                                    </tr>
                                    <tr>
                                        <td>Approved by</td>
                                        <td><span t-esc="h['approve_by']"/></td>
                                        <td><span t-esc="h['approved_job_title']"/></td>
                                        <td><img t-if="h['signature_approved']" t-att-src="'data:image/png;base64,%s' % h['signature_approved']" style="max-height: 45px;" /></td>
                                        <td><span t-esc="h['approve_date']"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <record id="budget_finance_report" model="ir.actions.report">
            <field name="name">Finance Report</field>
            <field name="model">finance.report.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="paperformat_id" ref="budget_report.create_finance_paper_format"/>
            <field name="report_name">budget_report.budget_finance_report_info</field>
            <field name="report_file">budget_report.budget_finance_report_info</field>
            <field name="binding_model_id" ref="model_finance_report_wizard"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
