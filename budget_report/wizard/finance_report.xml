<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_finance_report_wizard_form" model="ir.ui.view">
            <field name="name">Finance Report Wizard</field>
            <field name="model">finance.report.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Budget Report">
                    <group>
                        <group>
                            <field name="budget_id" options="{'no_quick_create': True, 'no_create_edit' : True}" domain="[('state', '=', budget_state)]"/>

                            <field name="report_type" invisible="more_details == False" widget="radio" options="{'horizontal':true}"/>
                            <field name="company_id" invisible="1"/>
                            <field name="project_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="quarter_ids" widget="many2many_tags" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                            <!--                                   domain="[('state', '=', budget_state)]"/>-->
                            <!-- <field name="state_id" invisible="report_type != 'summary'" required="report_type == 'summary'"/> -->
                            <field name="budget_line_id" invisible="report_type != 'summary'" required="report_type == 'summary'" domain="[('project_id', '=', project_id)]"/>
                            <field name="more_details" invisible="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_report" string="Print" type="object" class="oe_highlight"/>
                        <!-- <button string="Generate xlsx" name="action_generate_xlsx_report" type="object" -->
                                <!-- class="btn-primary"/> -->
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_finance_report_wizard_action" model="ir.actions.act_window">
            <field name="name">Finance Report</field>
            <field name="res_model">finance.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="type">ir.actions.act_window</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>