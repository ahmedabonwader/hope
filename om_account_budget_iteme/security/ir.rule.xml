<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_budget_admin_project_rule" model="ir.rule">
            <field name="name">Account Budget Admin - See All Project</field>
            <field name="model_id" ref="om_account_budget_iteme.model_crossovered_budget"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('om_account_budget_iteme.group_account_administrator'))]"/>
        </record>

        <record id="account_budget_donor_rule" model="ir.rule">
            <field name="name">Donor: See Own Project Budget Only</field>
            <field name="model_id" ref="om_account_budget_iteme.model_crossovered_budget"/>
            <field name="domain_force">[('project_id', 'in', user.project_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('om_account_budget_iteme.group_accounting_doner'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>