<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_line_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='analytic_distribution']" position="after">
                <field name="quarter_id" domain="[('project_id', '=', project_id)]" required="check_quarter == True"/>
                <field name="check_quarter" optional="hide"/>
                <field name="budget_item_line_id" options="{'no_create': True}"
                       required="(parent.required_rate == True)"
                />
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='tax_ids']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            
            <!-- <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='quantity']" position="after">
                <field name="qty"/>
                <field name="frequency"/>
            </xpath> -->
        
        </field>
    </record>
</odoo>