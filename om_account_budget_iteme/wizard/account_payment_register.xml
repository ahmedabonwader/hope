<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_payment_register_form_inherit" model="ir.ui.view">
            <field name="name">account.payment.register.form</field>
            <field name="model">account.payment.register</field>
            <field name="inherit_id" ref="account.view_account_payment_register_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_bank_id']" position="after">
                    <field name="project_id" readonly="1" invisible="1"/>
                    <field name="rate_check" readonly="1" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='payment_date']" position="before">
                    <field name="rate" invisible="1"/>
                    <field name="line_code" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>