<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit account move form view -->
    <record id="account_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="ref" position="after">
                <field name="project_id"  readonly="state != 'draft'"/>
            </field>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='analytic_distribution']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/form/sheet/group//field[@name='analytic_distribution']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit account move tree view -->
    <record id="account_move_tree_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <field name="date" position="after">
                <field name="project_id" optional="show"/>
            </field>
        </field>
    </record>

    <!-- Inherit account move search view -->
    <record id="account_move_search_inherit" model="ir.ui.view">
        <field name="name">account.move.search.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="project_id"/>
            </field>
        </field>
    </record>
    
</odoo>
